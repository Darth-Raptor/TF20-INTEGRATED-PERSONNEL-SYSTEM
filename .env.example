NODE_ENV=development

# Required for Area 1 Prisma validation, migration, and seed work.
# mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=mysql://tf20_user:replace-password@localhost:3306/tf20

# Required for npm run test:integration. Must point at a separate disposable
# database whose name includes test, ci, or spec.
TEST_DATABASE_URL=mysql://tf20_user:replace-password@localhost:3306/tf20_test

# Planned for Areas 2-6 identity, auth, and operations implementation.
# These are placeholders only; real values stay outside git.
SESSION_SECRET=replace-with-session-secret
APP_BASE_URL=https://example.invalid
DISCORD_CLIENT_ID=replace-with-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret
DISCORD_REDIRECT_URI=https://example.invalid/auth/discord/callback
DISCORD_APPROVED_GUILD_ID=replace-with-approved-guild-id
DISCORD_BOT_TOKEN=replace-with-bot-token-for-guild-verification
BOOTSTRAP_DISCORD_ID=replace-with-one-time-setup-discord-id
SESSION_TTL_DAYS=7
RECENT_AUTH_WINDOW_MINUTES=15

# Optional IPS -> Discord bot recruiting notification bridge.
DISCORD_RECRUITING_BRIDGE_ENABLED=false
DISCORD_RECRUITING_BRIDGE_URL=http://127.0.0.1:8787/ips/recruiting-event
DISCORD_RECRUITING_BRIDGE_SECRET=replace-with-shared-bridge-secret
DISCORD_RECRUITING_BRIDGE_INTERVAL_MS=15000
DISCORD_RECRUITING_BRIDGE_TIMEOUT_MS=8000
DISCORD_RECRUITING_BRIDGE_BATCH_SIZE=10
DISCORD_RECRUITING_BRIDGE_MAX_ATTEMPTS=8

# Reserved backend-only future Steam integration values.
STEAM_API_KEY=replace-with-steam-api-key
STEAM_OPENID_REALM=https://example.invalid
STEAM_OPENID_RETURN_URL=https://example.invalid/auth/steam/callback

# Production notes:
# - Production uses env-only runtime configuration outside git.
# - Real auth values, session secrets, and one-time bootstrap values stay outside git.
# - Rotate exposed or suspected-exposed secrets instead of reusing them.
# - Do not add official catalog values here.
